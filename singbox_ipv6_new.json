        "server": "local"
      },
      {
        "process_name": [
          "Microsoft Outlook",
          "motrix-next-engine",
          "aria2c.exe",
          "fdm.exe",
          "folx.exe",
          "nettransport.exe",
          "thunder.exe",
          "transmission.exe",
          "utorrent.exe",
