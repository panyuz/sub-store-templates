        "rule_set": ["cn_domain", "microsoft@cn"],
        "server": "dns_direct"
      },
      {
        "query_type": ["A", "AAAA"],
        "rule_set": "proxy_domain",
        "server": "fakeip"
      },
      {
        "rule_set": "proxy_domain",
        "invert": true,
        "action": "evaluate",
        "server": "dns_proxy",
        "client_subnet": "114.114.114.114/24"
