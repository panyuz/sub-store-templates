        "server": "local"
      },
      {
        "domain": ["ghfast.top", "cdn.jsdelivr.net"],
        "domain_suffix": [
          "tplogin.cn",
          "router.asus.com",
          "tendawifi.com",
          "tplinkwifi.net",
          "app-measurement.com",
          "hm.baidu.com",
