        "tag": "DirectDNS",
        "type": "quic",
        "server": "dns.alidns.com",
        "domain_resolver": "dns_hosts"
      },
      {
        "tag": "DirectDNS_Fallback",
        "type": "https",
        "server": "doh.pub",
        "domain_resolver": "dns_hosts"
      },
      {
        "tag": "ProxyDNS",
        "type": "https",
        "server": "dns.google",
        "domain_resolver": "dns_hosts",
        "detour": "🚀 节点选择"
      },
      {
        "tag": "ProxyDNS_Fallback",
        "type": "https",
        "server": "cloudflare-dns.com",
        "domain_resolver": "dns_hosts",
        "detour": "🚀 节点选择"
      }
    ],
    "rules": [
      {
        "clash_mode": "direct",
        "server": "DirectDNS"
      },
      {
        "clash_mode": "global",
        "server": "ProxyDNS"
      },
      {
        "domain_suffix": [
          "lan",
          "local"
        ],
        "server": "dns_resolver"
      },
      {
        "rule_set": [
          "private"
        ],
        "server": "dns_resolver"
      },
      {
        "rule_set": [
          "ads"
        ],
        "action": "predefined"
      },
      {
        "rule_set": [
          "microsoft-cn",
          "apple-cn",
          "google-cn",
          "games-cn",
          "cn"
        ],
        "server": "DirectDNS"
      },
      {
        "domain": [
          "mc.manuscriptcentral.com",
          "manuscriptcentral.com"
        ],
        "server": "DirectDNS_Fallback"
      },
      {
        "rule_set": [
          "games",
          "ai",
          "downloader",
          "proxy",
          "OpenAI",
          "Claude",
          "Gemini",
          "PayPal"
        ],
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "ProxyDNS"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "ProxyDNS_Fallback"
      }
    ],
    "final": "ProxyDNS",
    "strategy": "prefer_ipv4",
    "disable_cache": false,
    "disable_expire": false,
    "independent_cache": true,
    "reverse_mapping": true
